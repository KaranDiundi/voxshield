<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Shield Icon / Logo Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/shieldIcon"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:gravity="center"
                android:text="🛡️"
                android:textSize="48sp"
                android:background="@drawable/shield_bg"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VoxShield"
                android:textColor="@color/text_primary"
                android:textSize="32sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_subtitle"
                android:textColor="@color/primary_light"
                android:textSize="16sp"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif" />
        </LinearLayout>

        <!-- Status Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/statusCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/background_card"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/statusDot"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/status_dot_off" />

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_off"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginStart="12dp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- Waveform Visualization -->
                <LinearLayout
                    android:id="@+id/waveformContainer"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="16dp"
                    android:visibility="gone">

                    <View android:id="@+id/wave1" android:layout_width="4dp" android:layout_height="20dp"
                        android:layout_margin="2dp" android:background="@color/primary" />
                    <View android:id="@+id/wave2" android:layout_width="4dp" android:layout_height="35dp"
                        android:layout_margin="2dp" android:background="@color/primary" />
                    <View android:id="@+id/wave3" android:layout_width="4dp" android:layout_height="15dp"
                        android:layout_margin="2dp" android:background="@color/primary" />
                    <View android:id="@+id/wave4" android:layout_width="4dp" android:layout_height="45dp"
                        android:layout_margin="2dp" android:background="@color/primary" />
                    <View android:id="@+id/wave5" android:layout_width="4dp" android:layout_height="25dp"
                        android:layout_margin="2dp" android:background="@color/primary" />
                    <View android:id="@+id/wave6" android:layout_width="4dp" android:layout_height="50dp"
                        android:layout_margin="2dp" android:background="@color/primary" />
                    <View android:id="@+id/wave7" android:layout_width="4dp" android:layout_height="30dp"
                        android:layout_margin="2dp" android:background="@color/primary" />
                    <View android:id="@+id/wave8" android:layout_width="4dp" android:layout_height="40dp"
                        android:layout_margin="2dp" android:background="@color/primary" />
                    <View android:id="@+id/wave9" android:layout_width="4dp" android:layout_height="20dp"
                        android:layout_margin="2dp" android:background="@color/primary" />
                    <View android:id="@+id/wave10" android:layout_width="4dp" android:layout_height="35dp"
                        android:layout_margin="2dp" android:background="@color/primary" />
                    <View android:id="@+id/wave11" android:layout_width="4dp" android:layout_height="15dp"
                        android:layout_margin="2dp" android:background="@color/primary" />
                    <View android:id="@+id/wave12" android:layout_width="4dp" android:layout_height="45dp"
                        android:layout_margin="2dp" android:background="@color/primary" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Result Card (hidden by default) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/background_card"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvResultIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="48sp" />

                <TextView
                    android:id="@+id/tvResultTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvResultConfidence"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tvResultRisk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Actions -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCallProtection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            style="@style/VoxShield.Button.Primary"
            android:text="@string/btn_call_protection"
            app:icon="@android:drawable/ic_menu_call"
            app:iconGravity="textStart"
            app:iconPadding="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnalyzeAudio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            style="@style/VoxShield.Button.Secondary"
            android:text="@string/btn_analyze_audio"
            app:icon="@android:drawable/ic_btn_speak_now"
            app:iconGravity="textStart"
            app:iconPadding="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            style="@style/VoxShield.Button.Secondary"
            android:text="@string/btn_view_history"
            app:icon="@android:drawable/ic_menu_recent_history"
            app:iconGravity="textStart"
            app:iconPadding="12dp" />

        <!-- Server Config -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/background_card"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Server Configuration"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="@color/primary"
                    app:hintTextColor="@color/text_secondary"
                    android:hint="API Base URL">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etServerUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="http://10.0.2.2:8000"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:inputType="textUri" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
